# ── Supabase ────────────────────────────────────────────────────────────────
# Settings → API in your Supabase project dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-only, never expose to client

# ── AI Agent ────────────────────────────────────────────────────────────────
# console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Scraper service (mugshot proxy) ─────────────────────────────────────────
# The FastAPI scraper, reachable from the Next.js server only (loopback or
# private network). Browser traffic goes through /api/mugshot/[adc].
SCRAPER_BASE_URL=http://127.0.0.1:8000
